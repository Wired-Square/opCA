{
  "name": "opca",
  "private": true,
  "version": "0.99.14",
  "type": "module",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "tauri": "tauri",
    "tauri:build:debug": "tauri build --debug",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release:rebuild": "node scripts/release.js rebuild",
    "test": "cargo test -p opca-core",
    "test:e2e": "cargo test -p opca-core --test e2e",
    "notary:history": "scripts/notary.sh history",
    "notary:log": "scripts/notary.sh log",
    "notary:validate": "xcrun stapler validate"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1"
  }
}
